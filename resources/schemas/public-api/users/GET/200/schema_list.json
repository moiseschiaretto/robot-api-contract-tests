{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GET /users - 200 (lista)",
  "type": "object",
  "required": ["users", "total", "skip", "limit"],
  "properties": {
    "users": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "username", "email"],
        "properties": {
          "id": { "type": "integer" },
          "username": { "type": "string" },
          "email": { "type": "string" }
        }
      }
    },
    "total": { "type": "integer" },
    "skip": { "type": "integer" },
    "limit": { "type": "integer" }
  }
}
